{
  "name": "siaps-exporter",
  "version": "0.1.2",
  "description": "Automação de download de planilhas do SIAPS pro Google Sheets",
  "main": "out/main/main.js",
  "author": "Lucas Simao",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --win --publish=never",
    "dist:publish": "electron-vite build && electron-builder --win --publish=always",
    "test:scraper": "tsx src/scraper/test.ts",
    "test:processor": "tsx src/processor/test.ts",
    "test:sheets": "tsx src/sheets/test.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.0",
    "electron-updater": "^6.8.9",
    "googleapis": "^140.0.0",
    "playwright": "^1.45.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.0"
  }
